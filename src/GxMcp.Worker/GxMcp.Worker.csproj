<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <OutputType>Exe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Platforms>x86</Platforms>
    <PlatformTarget>x86</PlatformTarget>
    <OutputPath>bin\$(Configuration)\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <GenerateBindingRedirectsOutputType>true</GenerateBindingRedirectsOutputType>
    <NoWarn>$(NoWarn);MSB3277</NoWarn>
    <Version>2.29.2</Version>
    <AssemblyVersion>2.29.2.0</AssemblyVersion>
    <FileVersion>2.29.2.0</FileVersion>
    <InformationalVersion>2.29.2</InformationalVersion>
  </PropertyGroup>

  <PropertyGroup>
    <GX_PATH Condition="'$(GX_PATH)' == ''">C:\Program Files (x86)\GeneXus\GeneXus18</GX_PATH>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Artech.Architecture.Common">
      <HintPath>$(GX_PATH)\Artech.Architecture.Common.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Microsoft.Build.Framework" />
    <Reference Include="Microsoft.Build.Utilities.v4.0" />
    <Reference Include="Microsoft.Build.Utilities.Core">
      <HintPath>$(GX_PATH)\Microsoft.Build.Utilities.Core.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Genexus.Common">
      <HintPath>$(GX_PATH)\Artech.Genexus.Common.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Udm.Framework">
      <HintPath>$(GX_PATH)\Artech.Udm.Framework.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Architecture.BL.Framework">
      <HintPath>$(GX_PATH)\Artech.Architecture.BL.Framework.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Architecture.Language">
      <HintPath>$(GX_PATH)\Artech.Architecture.Language.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Common.Language">
      <HintPath>$(GX_PATH)\Artech.Common.Language.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Architecture.Interfaces">
      <HintPath>$(GX_PATH)\Artech.Architecture.Interfaces.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Common.Properties">
      <HintPath>$(GX_PATH)\Artech.Common.Properties.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Common.Helpers">
      <HintPath>$(GX_PATH)\Artech.Common.Helpers.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Common.Controls">
      <HintPath>$(GX_PATH)\Artech.Common.Controls.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Common">
      <HintPath>$(GX_PATH)\Artech.Common.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Architecture.UI.Framework">
      <HintPath>$(GX_PATH)\Artech.Architecture.UI.Framework.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- genexus_gam: concrete IIntegratedSecurityService implementation lives in the GAM
         package assembly, not Artech.Architecture.Common. IIntegratedSecurityService itself
         doesn't implement IGxService, so it can't go through Services.TryGetService<T>()'s
         generic constraint directly — GamService resolves the concrete
         Artech.Packages.GAM.IntegratedSecurityService (which does implement IGxService) and
         casts to the interface. -->
    <Reference Include="Artech.Packages.GAM">
      <HintPath>$(GX_PATH)\Packages\Artech.Packages.GAM.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- Team Development headless auth: TokenAuthorizationManager.GetToken + CommunicationData
         live here. The GeneXus Server uses OAuth; the UI.Framework login path that registers
         the session credential doesn't resolve headless, so we acquire the token directly. -->
    <Reference Include="Artech.Packages.TeamDevClient.BL">
      <HintPath>$(GX_PATH)\Packages\Artech.Packages.TeamDevClient.BL.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- genexus_security action=scan_native: the native GeneXus Security Scanner
         (ISecurityScannerService.Scan) + its query/plan/output types. -->
    <Reference Include="GeneXus.SecurityScanner.Common">
      <HintPath>$(GX_PATH)\GeneXus.SecurityScanner.Common.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- genexus_gxserver action=pipeline_*: IContinuousIntegrationService (CI pipelines). -->
    <Reference Include="GeneXus.TeamDevClient.Architecture.BL">
      <HintPath>$(GX_PATH)\GeneXus.TeamDevClient.Architecture.BL.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- Concrete service impls not registered in the headless worker's service registry
         (IDE-package services). We construct them directly (public parameterless ctors) and
         cast to the interface — same idiom as GamService. GenexusBL: ModelInformationService,
         DeploymentTargetService, DeployService. Specifier: SpecifierService. -->
    <Reference Include="Artech.Packages.GenexusBL">
      <HintPath>$(GX_PATH)\Packages\Artech.Packages.GenexusBL.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Artech.Packages.Specifier">
      <HintPath>$(GX_PATH)\Packages\Artech.Packages.Specifier.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Configuration" />
    <Reference Include="System.Data" />
    <Reference Include="System.IO.Compression.FileSystem" />
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Web" />
    <Reference Include="System.Management" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Playbooks\*.md" />
  </ItemGroup>
</Project>
