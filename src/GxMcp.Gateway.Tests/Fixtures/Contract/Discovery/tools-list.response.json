      "description": "Build, validate, index, or poll the KB. Long ops are async with operationId. See genexus://kb/tool-help/genexus_lifecycle for actions and target formats.",
      "inputSchema": {
        "properties": {
          "action": {
            "enum": [
              "build",
              "cancel",
              "rebuild",
              "reorg",
              "validate",
              "validate-kb",
              "sync",
              "index",
              "status",
              "result",
              "snapshots-list",
              "snapshots-restore"
            ],
            "type": "string"
          },
          "buildPlanCap": {
            "description": "Build: max expanded nodes before BuildPlanTooLarge (default 200).",
            "type": "integer"
          },
          "code": {
            "type": "string"
          },
          "compact": {
            "description": "Status: when true (default) returns counts + top-10 errors + warning dedup. Set false for legacy full Output/Errors[].",
            "type": "boolean"
          },
          "estimated_seconds": {
            "description": "Build: <20 forces sync fast-path (one turn); >=20 (default 60) goes async.",
            "type": "integer"
          },
          "force": {
            "description": "Index: when true, clears in-memory + on-disk snapshot and runs a full SDK rescan. Use when impact analyze reports indexEdgesMissing or after adding/renaming objects.",
            "type": "boolean"
          },
          "includeCallees": {
            "description": "Build: auto-expand target via call graph so callees compile before callers (fixes CS0246 from missing DLLs). Default transitive.",
            "enum": [
              "none",
              "direct",
              "transitive"
            ],
            "type": "string"
          },
          "kb": {
            "description": "Target KB. Required when 2+ open.",
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "snapshotPath": {
            "type": "string"
          },
          "target": {
            "description": "Object name(s), taskId, job_id, or op:<operationId>.",
            "type": "string"
          },
          "wait_seconds": {
            "description": "Status: 0-25. >0 long-polls server-side until terminal or timeout.",
            "type": "integer"
          }
        },
        "required": [
          "action"
        ],
        "type": "object"
      },
      "name": "genexus_lifecycle"
    },
