    {
      "description": "Edit an object part. Pass name or targets (mutually exclusive). Mode: full | patch. Use dryRun before persisting. For WWP screens edit the host WorkWithPlus<X>.PatternInstance — NOT the WebForm of the parent (gets overwritten on reapply). See recipe 'edit_pattern_instance' and 'add_custom_button' via genexus_recipe.",
      "inputSchema": {
        "properties": {
          "content": {
            "type": "string"
          },
          "context": {
            "type": "string"
          },
          "dryRun": {
            "type": "boolean"
          },
          "expectedCount": {
            "type": "integer"
          },
          "kb": {
            "description": "Target KB. Required when 2+ open.",
            "type": "string"
          },
          "mode": {
            "enum": [
              "full",
              "patch",
              "ops"
            ],
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "operation": {
            "enum": [
              "Replace",
              "Insert_After",
              "Append"
            ],
            "type": "string"
          },
          "ops": {
            "description": "RFC 6902 JSON-Patch ops. Supported: add, remove, replace, test.",
            "items": {
              "properties": {
                "op": {
                  "enum": [
                    "add",
                    "remove",
                    "replace",
                    "test"
                  ],
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "value": {}
              },
              "required": [
                "op",
                "path"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "part": {
            "type": "string"
          },
          "patch": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "properties": {
                  "find": {
                    "type": "string"
                  },
                  "replace": {
                    "type": "string"
                  }
                },
                "required": [
                  "find",
                  "replace"
                ],
                "type": "object"
              }
            ],
            "description": "Legacy string replacement OR {find, replace} JSON object. Prefer separate operation/context/content params for new code."
          },
          "return_post_state": {
            "description": "Set false to omit post_state.diff from the response (default true).",
            "type": "boolean"
          },
          "targets": {
            "items": {
              "properties": {
                "content": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              },
              "required": [
                "name",
                "content"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "type": {
            "type": "string"
          },
          "verbose": {
            "description": "When true, adds slices (±15 lines around each hunk) to post_state (default false).",
            "type": "boolean"
          },
          "verifyRollback": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "name": "genexus_edit"
    },
    {
      "description": "Edit an object then rebuild its callers in one call. Returns edit diff + impact + build operationId. See genexus://kb/tool-help/genexus_edit_and_build for examples.",
