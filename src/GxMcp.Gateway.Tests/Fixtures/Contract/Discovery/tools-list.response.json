{
  "tools": [
    {
      "description": "Add a variable to the Variables part of a GeneXus object.",
      "inputSchema": {
        "properties": {
          "kb": {
            "description": "Target KB. Required when 2+ open.",
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "typeName": {
            "type": "string"
          },
          "varName": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "varName"
        ],
        "type": "object"
      },
      "name": "genexus_add_variable"
    },
    {
      "description": "Cross-object semantic analysis: impact, dependencies, complexity, naming, summary. See genexus://kb/tool-help/genexus_analyze for mode selection.",
      "inputSchema": {
        "properties": {
          "kb": {
            "description": "Target KB. Required when 2+ open.",
            "type": "string"
          },
          "mode": {
            "enum": [
              "linter",
              "navigation",
              "hierarchy",
              "impact",
              "data_context",
              "ui_context",
              "pattern_metadata",
              "summary"
            ],
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "waitForIndex": {
            "default": true,
            "description": "For mode=impact: when true (default) block up to 30s for the index to be Ready; when false return a status envelope immediately if the index is Cold/Reindexing.",
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "mode"
        ],
        "type": "object"
      },
      "name": "genexus_analyze"
    },
    {
      "description": "Apply a GeneXus pattern (e.g. WorkWithPlus) to a parent object. Equivalent to IDE 'Right-click → Apply Pattern'. ALWAYS run genexus_inspect first to confirm parentType — Transaction (family-gen, no template) vs WebPanel/SDPanel (direct-attach, pass settings.template). Other types are rejected. See recipe 'wwp_on_transaction' or 'wwp_on_webpanel' via genexus_recipe.",
      "inputSchema": {
        "properties": {
          "kb": {
            "description": "Target KB. Required when 2+ open.",
            "type": "string"
          },
          "name": {
            "description": "Target KBObject name (Transaction, WebPanel, etc.)",
            "type": "string"
          },
          "pattern": {
            "description": "Pattern key ('WorkWithPlus') or GUID",
            "type": "string"
          },
          "reapply": {
            "default": false,
            "description": "Re-run on existing instance instead of first-time apply",
            "type": "boolean"
          },
          "settings": {
            "description": "Optional pattern-instance settings (deeply nested config tree from the pattern's settings dialog)",
            "type": "object"
          },
          "validate": {
            "default": false,
            "description": "After apply, build the generated host to verify it compiles cleanly. Response gains a `validation` block: {status: ok|failed|timeout, errorCount, warningCount, errors[], warnings[], durationMs}. Adds 60-180s wall time but catches binding/wiring errors the LLM would only see by opening the IDE.",
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "pattern"
        ],
        "type": "object"
      },
      "name": "genexus_apply_pattern"
    },
    {
      "description": "Apply a visual template: kpi_header (title,kpi1,kpi2,kpi3) | empty_state (caption,image) | confirm_dialog (confirmEvent,cancelEvent). Template args go in args.",
      "inputSchema": {
        "properties": {
          "args": {
            "type": "object"
          },
          "dryRun": {
            "type": "boolean"
          },
          "kb": {
            "description": "Target KB. Required when 2+ open.",
