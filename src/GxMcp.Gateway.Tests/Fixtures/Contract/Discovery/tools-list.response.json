          },
          "name": {
            "type": "string"
          },
          "part": {
            "type": "string"
          },
          "template": {
            "enum": [
              "kpi_header",
              "empty_state",
              "confirm_dialog"
            ],
            "type": "string"
          }
        },
        "required": [
          "name",
          "template"
        ],
        "type": "object"
      },
      "name": "genexus_apply_template"
    },
