            "type": "integer"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "left": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "mode": {&#xD;
            "enum": [&#xD;
              "textVsText",&#xD;
              "currentVsText"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "right": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_diff"&#xD;
    },&#xD;
    {&#xD;
      "description": "Unified diff of generated files (.cs/.aspx/.js/.html) for an object vs a baseline.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "against": {&#xD;
            "default": "last-build",&#xD;
            "enum": [&#xD;
              "last-build",&#xD;
              "git-head"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_diff_generated"&#xD;
    },&#xD;
    {&#xD;
      "description": "Use to generate structured docs (wiki, sequence diagrams, health reports). Don't use for programmatic analysis (see genexus_analyze) or source (see genexus_read).",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "wiki",&#xD;
              "visualize",&#xD;
              "health"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "Object or domain name.",&#xD;
