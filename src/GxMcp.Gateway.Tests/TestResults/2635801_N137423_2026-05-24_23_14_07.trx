            "description": "Atomic batch: rollback prior successes on first Error.",&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "targets"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_bulk_edit"&#xD;
    },&#xD;
    {&#xD;
      "description": "Create any IDE-creatable object (Transaction, Procedure, WebPanel, SDT, Domain, Dashboard, ...). Domain takes dataType+length or enumValues. NOT for WorkWithPlus (use genexus_apply_pattern) or input-bearing popups (use genexus_create_popup).",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "basedOn": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "dataType": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "decimals": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "description": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "enumValues": {&#xD;
            "items": {&#xD;
              "type": "object"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "length": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "signed": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "type",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_create_object"&#xD;
    },&#xD;
    {&#xD;
      "description": "Create popup WebPanel with Form type=\"layout\" body (radio/combo render editable). Spec: title, inputs, buttons, inParms, outParms.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "dryRun": {&#xD;
            "description": "Validate spec + render layout XML without persisting the WebPanel.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "WebPanel name (created or updated).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "spec": {&#xD;
            "description": "Popup spec.",&#xD;
            "properties": {&#xD;
              "buttons": {&#xD;
                "items": {&#xD;
                  "properties": {&#xD;
                    "caption": {&#xD;
                      "type": "string"&#xD;
                    },&#xD;
                    "event": {&#xD;
                      "type": "string"&#xD;
                    }&#xD;
                  },&#xD;
                  "type": "object"&#xD;
                },&#xD;
                "type": "array"&#xD;
              },&#xD;
              "description": {&#xD;
                "type": "string"&#xD;
              },&#xD;
              "inParms": {&#xD;
                "description": "e.g. [\"X:Numeric(2)\"]",&#xD;
                "items": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "type": "array"&#xD;
              },&#xD;
              "inputs": {&#xD;
                "items": {&#xD;
                  "properties": {&#xD;
                    "label": {&#xD;
                      "type": "string"&#xD;
                    },&#xD;
                    "options": {&#xD;
                      "items": {&#xD;
                        "properties": {&#xD;
                          "label": {&#xD;
                            "type": "string"&#xD;
                          },&#xD;
                          "value": {&#xD;
                            "type": "string"&#xD;
                          }&#xD;
                        },&#xD;
                        "type": "object"&#xD;
                      },&#xD;
                      "type": "array"&#xD;
                    },&#xD;
                    "showWhen": {&#xD;
                      "description": "e.g. \"X == 'S'\"; emits Refresh toggling group visibility.",&#xD;
                      "type": "string"&#xD;
                    },&#xD;
                    "type": {&#xD;
                      "enum": [&#xD;
                        "radio",&#xD;
                        "combo",&#xD;
                        "text"&#xD;
                      ],&#xD;
                      "type": "string"&#xD;
                    },&#xD;
                    "varName": {&#xD;
                      "type": "string"&#xD;
                    }&#xD;
                  },&#xD;
                  "required": [&#xD;
                    "type",&#xD;
                    "varName"&#xD;
                  ],&#xD;
                  "type": "object"&#xD;
                },&#xD;
                "type": "array"&#xD;
              },&#xD;
              "outParms": {&#xD;
                "items": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "type": "array"&#xD;
              },&#xD;
              "title": {&#xD;
                "type": "string"&#xD;
              }&#xD;
            },&#xD;
            "type": "object"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "spec"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_create_popup"&#xD;
    },&#xD;
    {&#xD;
