          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_worker_pool"&#xD;
    },&#xD;
    {&#xD;
      "description": "Reload worker. modes: soft (drain+respawn), hard (copy sourceDir+respawn), warm (EXPERIMENTAL; persist index snapshot). force=true: gateway kills directly. See tool-help.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "drainTimeoutMs": {&#xD;
            "description": "Soft/warm only; default 30000.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "force": {&#xD;
            "description": "Bypass drain; gateway kills + respawns. Use when worker is wedged.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "mode": {&#xD;
            "enum": [&#xD;
              "soft",&#xD;
              "hard",&#xD;
              "warm"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "sourceDir": {&#xD;
            "description": "Required for mode=hard.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_worker_reload"&#xD;
    }&#xD;
  ]&#xD;
}
Actual:
{&#xD;
  "tools": [&#xD;
    {&#xD;
