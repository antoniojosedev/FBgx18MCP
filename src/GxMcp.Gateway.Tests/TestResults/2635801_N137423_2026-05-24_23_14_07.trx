        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_build_plan"&#xD;
    },&#xD;
    {&#xD;
      "description": "Apply N independent edits. Item: {name,part?,content,type?,dryRun?}. stopOnError halts at first fail. transactional=true rolls back on first Error.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "dryRun": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
