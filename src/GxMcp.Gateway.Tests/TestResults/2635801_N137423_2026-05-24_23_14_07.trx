    },&#xD;
    {&#xD;
      "description": "Static index advisor. analyze=KB-wide For-each scan; suggest_indexes=covering DDL per Transaction; report=top-10 unindexed hot paths (+markdown).",&#xD;
      "inputSchema": {&#xD;
