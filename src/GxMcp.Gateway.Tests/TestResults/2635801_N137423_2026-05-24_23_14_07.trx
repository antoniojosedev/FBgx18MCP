            "type": "integer"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "signed": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
