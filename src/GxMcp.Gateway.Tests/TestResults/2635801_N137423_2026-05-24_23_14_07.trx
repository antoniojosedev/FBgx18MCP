            "type": "string"&#xD;
          },&#xD;
          "controlId": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "controlIds": {&#xD;
            "items": {&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
