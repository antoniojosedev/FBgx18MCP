    },&#xD;
    {&#xD;
      "description": "Forward prompt to OpenAI-compatible endpoint (env GXMCP_AI_COMPLETE_URL/_KEY/_MODEL). Errors: AiEndpointNotConfigured, AiEndpointError.",&#xD;
      "inputSchema": {&#xD;
