          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_doc"&#xD;
    },&#xD;
    {&#xD;
      "description": "Health check: GX install, KB state, worker, cache age, recent telemetry. Paste output for triage when something feels off.",&#xD;
      "inputSchema": {&#xD;
        "additionalProperties": false,&#xD;
        "properties": {},&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_doctor"&#xD;
    },&#xD;
    {&#xD;
      "description": "Edit object part. name or targets (exclusive). mode: full|patch|ops. dryRun first. For WWP edit host's PatternInstance NOT the parent WebForm (gets overwritten on reapply).",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "content": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "context": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "dryRun": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "expectedCount": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "mode": {&#xD;
            "enum": [&#xD;
              "full",&#xD;
              "patch",&#xD;
              "ops"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "operation": {&#xD;
            "enum": [&#xD;
              "Replace",&#xD;
              "Insert_After",&#xD;
              "Append"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "ops": {&#xD;
            "description": "RFC 6902 JSON-Patch ops. Supported: add, remove, replace, test.",&#xD;
            "items": {&#xD;
              "properties": {&#xD;
                "op": {&#xD;
                  "enum": [&#xD;
                    "add",&#xD;
                    "remove",&#xD;
                    "replace",&#xD;
                    "test"&#xD;
                  ],&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "path": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "value": {}&#xD;
              },&#xD;
              "required": [&#xD;
                "op",&#xD;
                "path"&#xD;
              ],&#xD;
              "type": "object"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "patch": {&#xD;
            "anyOf": [&#xD;
              {&#xD;
                "type": "string"&#xD;
              },&#xD;
              {&#xD;
                "properties": {&#xD;
                  "find": {&#xD;
                    "type": "string"&#xD;
                  },&#xD;
                  "replace": {&#xD;
                    "type": "string"&#xD;
                  }&#xD;
                },&#xD;
                "required": [&#xD;
                  "find",&#xD;
                  "replace"&#xD;
                ],&#xD;
                "type": "object"&#xD;
              }&#xD;
            ],&#xD;
            "description": "String or {find,replace} object. Prefer operation+context+content."&#xD;
          },&#xD;
          "replaceAll": {&#xD;
            "description": "patch mode only. Apply to ALL occurrences instead of requiring expectedCount to match exactly.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "return_post_state": {&#xD;
            "description": "Omit post_state.diff (default true).",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "targets": {&#xD;
            "items": {&#xD;
              "properties": {&#xD;
                "content": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "name": {&#xD;
                  "type": "string"&#xD;
                }&#xD;
              },&#xD;
              "required": [&#xD;
                "name",&#xD;
                "content"&#xD;
              ],&#xD;
              "type": "object"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "validate": {&#xD;
            "description": "strict (default) aborts on first error. best-effort applies what compiles. only runs in-memory, no persist.",&#xD;
            "enum": [&#xD;
              "strict",&#xD;
              "best-effort",&#xD;
              "only"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "verbose": {&#xD;
            "description": "Add ±15-line slices to post_state.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "verifyRollback": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "visualVerify": {&#xD;
            "default": false,&#xD;
            "description": "Post-edit headless screenshot + pixel-diff vs baseline. See tool-help.",&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_edit"&#xD;
    },&#xD;
    {&#xD;
      "description": "Edit + rebuild callers in one call. Returns edit diff + impact + build operationId.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "buildIncludeCallees": {&#xD;
            "default": "direct",&#xD;
            "enum": [&#xD;
              "none",&#xD;
              "direct",&#xD;
              "transitive"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "buildPlanCap": {&#xD;
            "default": 200,&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "content": {&#xD;
            "description": "New content. For mode=patch may be {find,replace} object.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "dryRun": {&#xD;
            "default": false,&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "mode": {&#xD;
            "default": "patch",&#xD;
            "enum": [&#xD;
              "full",&#xD;
              "patch"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Target object name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "description": "Part (Source, Rules, ...).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "patch": {&#xD;
            "anyOf": [&#xD;
              {&#xD;
                "type": "string"&#xD;
              },&#xD;
              {&#xD;
                "properties": {&#xD;
                  "find": {&#xD;
                    "type": "string"&#xD;
                  },&#xD;
                  "replace": {&#xD;
                    "type": "string"&#xD;
                  }&#xD;
                },&#xD;
                "required": [&#xD;
                  "find",&#xD;
                  "replace"&#xD;
                ],&#xD;
                "type": "object"&#xD;
              }&#xD;
            ],&#xD;
            "description": "Same shape as genexus_edit.patch. Auto-sets mode=patch."&#xD;
          },&#xD;
          "type": {&#xD;
            "description": "Disambiguates ambiguous names.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "visualVerify": {&#xD;
            "default": false,&#xD;
            "description": "Post-edit headless screenshot + pixel-diff vs baseline. See tool-help.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "waitForIndex": {&#xD;
            "default": true,&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "waitTimeoutMs": {&#xD;
            "default": 30000,&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "part"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_edit_and_build"&#xD;
    },&#xD;
    {&#xD;
      "description": "Semantic WebForm edits. Actions: add_textblock, add_button, set_visibility, remove_control, wrap_in_fieldset.",&#xD;
      "inputSchema": {&#xD;
        "examples": [&#xD;
          {&#xD;
            "action": "add_button",&#xD;
            "caption": "Confirmar",&#xD;
