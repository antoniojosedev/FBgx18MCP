        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_api"&#xD;
    },&#xD;
    {&#xD;
      "description": "Apply a pattern (e.g. WorkWithPlus) to a parent (IDE Right-click → Apply Pattern). Transaction=family-gen; WebPanel/SDPanel=direct-attach (pass settings.template). mode=diagnose returns findings without mutating.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "mode": {&#xD;
