          },&#xD;
          "includeSubordinated": {&#xD;
            "description": "action=ddl only.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "levelNumber": {&#xD;
            "description": "action=navigation only.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_sql"&#xD;
    },&#xD;
