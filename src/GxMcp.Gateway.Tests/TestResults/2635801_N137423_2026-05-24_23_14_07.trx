    },&#xD;
    {&#xD;
      "description": "Map NL transcript to a suggested tool call via regex intents. Returns {matched,dispatchedTool,dispatchedArgs}. Agent confirms; no dispatch.",&#xD;
      "inputSchema": {&#xD;
        "examples": [&#xD;
