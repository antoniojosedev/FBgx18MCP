          }&#xD;
        ],&#xD;
        "properties": {&#xD;
          "transcript": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "transcript"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_voice"&#xD;
    },&#xD;
    {&#xD;
