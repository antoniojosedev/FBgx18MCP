            "type": "string"&#xD;
          },&#xD;
          "title": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "workingDir": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "title"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_github"&#xD;
    },&#xD;
    {&#xD;
      "description": "Surface GxServer sync state (status/pending/conflicts/history). Read-only v1. Returns {connected:false} when KB is not linked.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "status",&#xD;
              "pending",&#xD;
              "conflicts",&#xD;
              "history"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "limit": {&#xD;
            "description": "history only; default 10, max 200.",&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_gxserver"&#xD;
    },&#xD;
    {&#xD;
      "description": "List/read/save/restore object history snapshots. restore + discard=true = IDE 'Discard changes' parity.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "list",&#xD;
              "get_source",&#xD;
              "save",&#xD;
              "restore"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "discard": {&#xD;
            "default": false,&#xD;
            "description": "restore-only: drop in-memory edits, restore last persisted baseline for (name,part).",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "dryRun": {&#xD;
            "description": "restore-only: return unified diff of snapshot vs current without writing.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "description": "Default 'Source'.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "snapshot": {&#xD;
            "description": "Snapshot token (timestamp or 'latest').",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "versionId": {&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_history"&#xD;
    },&#xD;
    {&#xD;
      "description": "Import a text file from disk into a GeneXus object part.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "inputPath": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "inputPath"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_import_object"&#xD;
    },&#xD;
    {&#xD;
      "description": "Inject SDT structures and Procedure signatures of called objects.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "recursive": {&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_inject_context"&#xD;
    },&#xD;
    {&#xD;
      "description": "Use to snapshot an object: metadata, variables, structure, signature. Raw shape, no source text — use genexus_read for code. runtimeIds requires a prior build.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "include": {&#xD;
            "items": {&#xD;
              "enum": [&#xD;
                "metadata",&#xD;
                "variables",&#xD;
                "signature",&#xD;
                "structure",&#xD;
                "parts",&#xD;
                "controls",&#xD;
                "events_repertoire",&#xD;
                "callers",&#xD;
                "runtimeIds"&#xD;
              ],&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "projection": {&#xD;
            "description": "minimal=name+type+lastUpdate; standard=default; verbose=all fields.",&#xD;
            "enum": [&#xD;
              "minimal",&#xD;
              "standard",&#xD;
              "verbose"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_inspect"&#xD;
    },&#xD;
    {&#xD;
      "description": "Manage open KBs and startup config. list/open/close/set_default operate on WorkerPool; set_startup/get_startup mirror IDE 'Set As Startup Object'.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "list",&#xD;
              "open",&#xD;
              "close",&#xD;
              "set_default",&#xD;
              "set_startup",&#xD;
              "get_startup"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "alias": {&#xD;
            "description": "KB alias. open: auto from path basename if omitted.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Object name (required for set_startup).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "path": {&#xD;
            "description": "Absolute KB path (required for open if alias not in config).",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb"&#xD;
    },&#xD;
    {&#xD;
      "description": "Compare two KBs without opening them. Filesystem walk of Objects/&lt;Type&gt;/&lt;Name&gt;/, no SDK. Returns {onlyInA[],onlyInB[],modified[]}.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kbA": {&#xD;
            "description": "KB alias or path.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kbB": {&#xD;
            "description": "KB alias or path.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "kbA",&#xD;
          "kbB"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb_diff"&#xD;
    },&#xD;
    {&#xD;
      "description": "Locate an object in the KB explorer tree (IDE Right-click → Locate). Returns modulePath, fullPath, up to 20 siblings.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "locate"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Object name.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb_explorer"&#xD;
    },&#xD;
    {&#xD;
      "description": "Copy one object's part files from another KB into the active KB. Deps NOT resolved. Re-index after.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "from": {&#xD;
            "description": "Source KB alias or path.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "description": "Object type (case-sensitive: WebPanel, Procedure, Transaction, ...).",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "from",&#xD;
          "name",&#xD;
          "type"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb_import"&#xD;
    },&#xD;
    {&#xD;
      "description": "Generate a Markdown README for the KB: entities, entry points, modules, top-edited objects.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "generate"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "outputPath": {&#xD;
            "description": "Absolute path to write README. Omit to return markdown inline.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb_readme"&#xD;
    },&#xD;
    {&#xD;
      "description": "SDK layout/WebForm ops: get_tree, set_property, find_controls, inspect_surface, scan_mutators.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "get_tree",&#xD;
              "set_property",&#xD;
              "find_controls",&#xD;
              "set_properties",&#xD;
              "inspect_surface",&#xD;
              "get_preview",&#xD;
              "scan_mutators",&#xD;
              "rename_printblock",&#xD;
              "add_printblock"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "changes": {&#xD;
            "items": {&#xD;
              "properties": {&#xD;
                "control": {&#xD;
