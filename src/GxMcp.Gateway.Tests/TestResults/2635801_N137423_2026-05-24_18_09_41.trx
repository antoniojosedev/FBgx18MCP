    },&#xD;
    {&#xD;
      "description": "Git blame for an object part. Returns commit/author/date per line; single line when line is set. Errors: KbNotInGit, PartNotTracked (with candidates[]).",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "context": {&#xD;
            "description": "Snippet ±N lines around the blamed line (default 2).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "filePath": {&#xD;
            "description": "KB-relative or absolute path to a tracked file. Use when name+part doesn't disambiguate.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "line": {&#xD;
            "description": "1-based line number. When omitted, blames the whole file.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Object name. Either name or filePath is required.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "description": "Default 'Source'.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_blame"&#xD;
    },&#xD;
    {&#xD;
      "description": "Open target in headless Chrome; capture console/network/exceptions. Skips with code='BrowserDriverUnavailable' when chrome-devtools-axi missing.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "capture": {&#xD;
            "description": "Default all three.",&#xD;
            "items": {&#xD;
              "enum": [&#xD;
                "console",&#xD;
                "network",&#xD;
                "exceptions"&#xD;
              ],&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "WebPanel name.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "target"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_browser_capture"&#xD;
    },&#xD;
    {&#xD;
      "description": "Walk the callee graph for target. Returns {nodes,edges,totalEstimatedSeconds}; estimates from per-tool p95 ring buffer. format=ascii adds rendered tree.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "format": {&#xD;
            "enum": [&#xD;
              "json",&#xD;
              "ascii"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "maxNodes": {&#xD;
            "description": "Cap node count (default 100, max 500).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "target": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "target"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_build_plan"&#xD;
    },&#xD;
    {&#xD;
      "description": "Apply N independent edits. Item: {name,part?,content,type?,dryRun?}. stopOnError halts at first fail. transactional=true rolls back on first Error.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "dryRun": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "stopOnError": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "targets": {&#xD;
            "items": {&#xD;
              "type": "object"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "transactional": {&#xD;
            "description": "Atomic batch: rollback prior successes on first Error.",&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "targets"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_bulk_edit"&#xD;
    },&#xD;
    {&#xD;
      "description": "Create any IDE-creatable object (Transaction, Procedure, WebPanel, SDT, Domain, Dashboard, ...). Domain takes dataType+length or enumValues. NOT for WorkWithPlus (use genexus_apply_pattern) or input-bearing popups (use genexus_create_popup).",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "basedOn": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "dataType": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "decimals": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "description": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "enumValues": {&#xD;
            "items": {&#xD;
              "type": "object"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "length": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "signed": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "type",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_create_object"&#xD;
    },&#xD;
    {&#xD;
      "description": "Create popup WebPanel with Form type=\"layout\" body (radio/combo render editable). Spec: title, inputs, buttons, inParms, outParms.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "dryRun": {&#xD;
            "description": "Validate spec + render layout XML without persisting the WebPanel.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "WebPanel name (created or updated).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "spec": {&#xD;
            "description": "Popup spec.",&#xD;
            "properties": {&#xD;
              "buttons": {&#xD;
                "items": {&#xD;
                  "properties": {&#xD;
                    "caption": {&#xD;
                      "type": "string"&#xD;
                    },&#xD;
                    "event": {&#xD;
                      "type": "string"&#xD;
                    }&#xD;
                  },&#xD;
                  "type": "object"&#xD;
                },&#xD;
                "type": "array"&#xD;
              },&#xD;
              "description": {&#xD;
                "type": "string"&#xD;
              },&#xD;
              "inParms": {&#xD;
                "description": "e.g. [\"X:Numeric(2)\"]",&#xD;
                "items": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "type": "array"&#xD;
              },&#xD;
              "inputs": {&#xD;
                "items": {&#xD;
                  "properties": {&#xD;
                    "label": {&#xD;
                      "type": "string"&#xD;
                    },&#xD;
                    "options": {&#xD;
                      "items": {&#xD;
                        "properties": {&#xD;
                          "label": {&#xD;
                            "type": "string"&#xD;
                          },&#xD;
                          "value": {&#xD;
                            "type": "string"&#xD;
                          }&#xD;
                        },&#xD;
                        "type": "object"&#xD;
                      },&#xD;
                      "type": "array"&#xD;
                    },&#xD;
                    "showWhen": {&#xD;
                      "description": "e.g. \"X == 'S'\"; emits Refresh toggling group visibility.",&#xD;
                      "type": "string"&#xD;
                    },&#xD;
                    "type": {&#xD;
                      "enum": [&#xD;
                        "radio",&#xD;
                        "combo",&#xD;
                        "text"&#xD;
                      ],&#xD;
                      "type": "string"&#xD;
                    },&#xD;
                    "varName": {&#xD;
                      "type": "string"&#xD;
                    }&#xD;
                  },&#xD;
                  "required": [&#xD;
                    "type",&#xD;
                    "varName"&#xD;
                  ],&#xD;
                  "type": "object"&#xD;
                },&#xD;
                "type": "array"&#xD;
              },&#xD;
              "outParms": {&#xD;
                "items": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "type": "array"&#xD;
              },&#xD;
              "title": {&#xD;
                "type": "string"&#xD;
              }&#xD;
            },&#xD;
            "type": "object"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "spec"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_create_popup"&#xD;
    },&#xD;
    {&#xD;
      "description": "Verify a WebPanel across engines (chrome + firefox/webkit via playwright). Returns {url,results,anyFailed}.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "browsers": {&#xD;
            "items": {&#xD;
              "enum": [&#xD;
                "chrome",&#xD;
                "firefox",&#xD;
                "safari",&#xD;
                "webkit"&#xD;
              ],&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "capture": {&#xD;
            "items": {&#xD;
              "enum": [&#xD;
                "screenshot",&#xD;
                "console"&#xD;
              ],&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "target"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_cross_browser"&#xD;
    },&#xD;
    {&#xD;
      "description": "Transaction↔DB schema drift. action=check structured; report adds markdown.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "check",&#xD;
              "report"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_db_drift"&#xD;
    },&#xD;
    {&#xD;
      "description": "Static index advisor. analyze=KB-wide For-each scan; suggest_indexes=covering DDL per Transaction; report=top-10 unindexed hot paths (+markdown).",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "analyze",&#xD;
              "suggest_indexes",&#xD;
              "report"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "format": {&#xD;
            "description": "report only. markdown adds paste-ready table.",&#xD;
            "enum": [&#xD;
              "json",&#xD;
              "markdown"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "Transaction name for suggest_indexes; optional filter for analyze.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_db_optimize"&#xD;
    },&#xD;
    {&#xD;
      "description": "Delete an object from the KB. Irreversible — confirm=true required.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "confirm": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "confirm"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_delete_object"&#xD;
    },&#xD;
    {&#xD;
      "description": "Remove a variable. Idempotent. Refuses GAM/WWP+ framework-managed vars.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "varName": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "varName"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_delete_variable"&#xD;
    },&#xD;
    {&#xD;
      "description": "Unified text diff. mode=textVsText|currentVsText.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "context": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "left": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "mode": {&#xD;
            "enum": [&#xD;
              "textVsText",&#xD;
              "currentVsText"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "right": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_diff"&#xD;
    },&#xD;
    {&#xD;
      "description": "Unified diff of generated files (.cs/.aspx/.js/.html) for an object vs a baseline.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "against": {&#xD;
            "default": "last-build",&#xD;
            "enum": [&#xD;
              "last-build",&#xD;
              "git-head"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_diff_generated"&#xD;
    },&#xD;
    {&#xD;
      "description": "Use to generate structured docs (wiki, sequence diagrams, health reports). Don't use for programmatic analysis (see genexus_analyze) or source (see genexus_read).",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "wiki",&#xD;
              "visualize",&#xD;
              "health"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "Object or domain name.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_doc"&#xD;
    },&#xD;
    {&#xD;
      "description": "Health check: GX install, KB state, worker, cache age, recent telemetry. Paste output for triage when something feels off.",&#xD;
      "inputSchema": {&#xD;
        "additionalProperties": false,&#xD;
        "properties": {},&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_doctor"&#xD;
    },&#xD;
    {&#xD;
      "description": "Edit object part. name or targets (exclusive). mode: full|patch|ops. dryRun first. For WWP edit host's PatternInstance NOT the parent WebForm (gets overwritten on reapply).",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "content": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "context": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "dryRun": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "expectedCount": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "mode": {&#xD;
            "enum": [&#xD;
              "full",&#xD;
              "patch",&#xD;
              "ops"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "operation": {&#xD;
            "enum": [&#xD;
              "Replace",&#xD;
              "Insert_After",&#xD;
              "Append"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "ops": {&#xD;
            "description": "RFC 6902 JSON-Patch ops. Supported: add, remove, replace, test.",&#xD;
            "items": {&#xD;
              "properties": {&#xD;
                "op": {&#xD;
                  "enum": [&#xD;
                    "add",&#xD;
                    "remove",&#xD;
                    "replace",&#xD;
                    "test"&#xD;
                  ],&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "path": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "value": {}&#xD;
              },&#xD;
              "required": [&#xD;
                "op",&#xD;
                "path"&#xD;
              ],&#xD;
              "type": "object"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "patch": {&#xD;
            "anyOf": [&#xD;
              {&#xD;
                "type": "string"&#xD;
              },&#xD;
              {&#xD;
                "properties": {&#xD;
                  "find": {&#xD;
                    "type": "string"&#xD;
                  },&#xD;
                  "replace": {&#xD;
                    "type": "string"&#xD;
                  }&#xD;
                },&#xD;
                "required": [&#xD;
                  "find",&#xD;
                  "replace"&#xD;
                ],&#xD;
                "type": "object"&#xD;
              }&#xD;
            ],&#xD;
            "description": "String or {find,replace} object. Prefer operation+context+content."&#xD;
          },&#xD;
          "replaceAll": {&#xD;
            "description": "patch mode only. Apply to ALL occurrences instead of requiring expectedCount to match exactly.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "return_post_state": {&#xD;
            "description": "Omit post_state.diff (default true).",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "targets": {&#xD;
            "items": {&#xD;
              "properties": {&#xD;
                "content": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "name": {&#xD;
                  "type": "string"&#xD;
                }&#xD;
              },&#xD;
              "required": [&#xD;
                "name",&#xD;
                "content"&#xD;
              ],&#xD;
              "type": "object"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "validate": {&#xD;
            "description": "strict (default) aborts on first error. best-effort applies what compiles. only runs in-memory, no persist.",&#xD;
            "enum": [&#xD;
              "strict",&#xD;
              "best-effort",&#xD;
              "only"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "verbose": {&#xD;
            "description": "Add ±15-line slices to post_state.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "verifyRollback": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "visualVerify": {&#xD;
            "default": false,&#xD;
            "description": "Post-edit headless screenshot + pixel-diff vs baseline. See tool-help.",&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_edit"&#xD;
    },&#xD;
    {&#xD;
      "description": "Edit + rebuild callers in one call. Returns edit diff + impact + build operationId.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "buildIncludeCallees": {&#xD;
            "default": "direct",&#xD;
            "enum": [&#xD;
              "none",&#xD;
              "direct",&#xD;
              "transitive"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "buildPlanCap": {&#xD;
            "default": 200,&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "content": {&#xD;
            "description": "New content. For mode=patch may be {find,replace} object.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "dryRun": {&#xD;
            "default": false,&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "mode": {&#xD;
            "default": "patch",&#xD;
            "enum": [&#xD;
              "full",&#xD;
              "patch"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Target object name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "description": "Part (Source, Rules, ...).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "patch": {&#xD;
            "anyOf": [&#xD;
              {&#xD;
                "type": "string"&#xD;
              },&#xD;
              {&#xD;
                "properties": {&#xD;
                  "find": {&#xD;
                    "type": "string"&#xD;
                  },&#xD;
                  "replace": {&#xD;
                    "type": "string"&#xD;
                  }&#xD;
                },&#xD;
                "required": [&#xD;
                  "find",&#xD;
                  "replace"&#xD;
                ],&#xD;
                "type": "object"&#xD;
              }&#xD;
            ],&#xD;
            "description": "Same shape as genexus_edit.patch. Auto-sets mode=patch."&#xD;
          },&#xD;
          "type": {&#xD;
            "description": "Disambiguates ambiguous names.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "visualVerify": {&#xD;
            "default": false,&#xD;
            "description": "Post-edit headless screenshot + pixel-diff vs baseline. See tool-help.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "waitForIndex": {&#xD;
            "default": true,&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "waitTimeoutMs": {&#xD;
            "default": 30000,&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "part"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_edit_and_build"&#xD;
    },&#xD;
    {&#xD;
      "description": "Semantic WebForm edits. Actions: add_textblock, add_button, set_visibility, remove_control, wrap_in_fieldset.",&#xD;
      "inputSchema": {&#xD;
        "examples": [&#xD;
          {&#xD;
            "action": "add_button",&#xD;
            "caption": "Confirmar",&#xD;
            "event": "OnConfirm",&#xD;
            "name": "WPMain"&#xD;
          },&#xD;
          {&#xD;
            "action": "set_visibility",&#xD;
            "controlId": "GrpDetail",&#xD;
            "name": "WPMain",&#xD;
            "visible": false&#xD;
          }&#xD;
        ],&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "add_textblock",&#xD;
              "add_button",&#xD;
              "set_visibility",&#xD;
              "remove_control",&#xD;
              "wrap_in_fieldset"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "caption": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "controlId": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "controlIds": {&#xD;
            "items": {&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "dryRun": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "event": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "format": {&#xD;
            "enum": [&#xD;
              "Text",&#xD;
              "HTML"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "legend": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "parent": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "position": {&#xD;
            "description": "first|last|after:&lt;id&gt;",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "visible": {&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_edit_form"&#xD;
    },&#xD;
    {&#xD;
      "description": "Recent invocations of an object from in-memory ring buffer. last clamped [1,50]. Resets on gateway restart.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "last": {&#xD;
            "description": "Max runs to return (default 10, max 50).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "Object name to filter on (matches args.target or args.name).",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "target"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_execution_history"&#xD;
    },&#xD;
    {&#xD;
      "description": "Deterministic PM-readable summary of an object: purpose, inputs/outputs, variables, top called procs/transactions, description. NOT raw source.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "depth": {&#xD;
            "description": "deep recurses one level into called objects.",&#xD;
            "enum": [&#xD;
              "shallow",&#xD;
              "deep"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_explain"&#xD;
    },&#xD;
    {&#xD;
      "description": "Export a GeneXus object part to a text file on disk.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "outputPath": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "overwrite": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "outputPath"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_export_object"&#xD;
    },&#xD;
    {&#xD;
      "description": "Export an object's full state (all parts) as a single JSON envelope.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_export_unified"&#xD;
    },&#xD;
    {&#xD;
      "description": "Generate new code or structures from templates or translations.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "scaffold",&#xD;
              "translate",&#xD;
              "sample"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "content": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_forge"&#xD;
    },&#xD;
    {&#xD;
      "description": "Format a GeneXus code snippet using worker rules.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "code": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "code"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_format"&#xD;
    },&#xD;
    {&#xD;
      "description": "Local friction journal under &lt;kbPath&gt;/.gx/friction.jsonl. action=append writes {atUtc,tool,message,severity}; action=tail returns last N entries.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "append",&#xD;
              "tail"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "message": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "n": {&#xD;
            "description": "Tail count (default 20, max 1000).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "severity": {&#xD;
            "enum": [&#xD;
              "info",&#xD;
              "warn",&#xD;
              "error",&#xD;
              "critical"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "tool": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_friction_log"&#xD;
    },&#xD;
    {&#xD;
      "description": "Emit INSERT statements with fake-but-typed data for a Transaction. SQL only; not executed.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
