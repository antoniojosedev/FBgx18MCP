      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "rows": {&#xD;
            "description": "1-1000; default 5.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "trn": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "trn"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_generate_sample_data"&#xD;
    },&#xD;
    {&#xD;
      "description": "Open a PR after pushing a branch. Shells `gh pr create` from KB path (or workingDir). Returns {status,url} or {code:'GhCliNotInstalled'}.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "create_pr"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "base": {&#xD;
            "description": "Base branch.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "body": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "title": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "workingDir": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "title"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_github"&#xD;
    },&#xD;
    {&#xD;
      "description": "Surface GxServer sync state (status/pending/conflicts/history). Read-only v1. Returns {connected:false} when KB is not linked.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "status",&#xD;
              "pending",&#xD;
              "conflicts",&#xD;
              "history"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "limit": {&#xD;
            "description": "history only; default 10, max 200.",&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_gxserver"&#xD;
    },&#xD;
    {&#xD;
      "description": "List/read/save/restore object history snapshots. restore + discard=true = IDE 'Discard changes' parity.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "list",&#xD;
              "get_source",&#xD;
              "save",&#xD;
              "restore"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "discard": {&#xD;
            "default": false,&#xD;
            "description": "restore-only: drop in-memory edits, restore last persisted baseline for (name,part).",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "dryRun": {&#xD;
            "description": "restore-only: return unified diff of snapshot vs current without writing.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "description": "Default 'Source'.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "snapshot": {&#xD;
            "description": "Snapshot token (timestamp or 'latest').",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "versionId": {&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_history"&#xD;
    },&#xD;
    {&#xD;
      "description": "Import a text file from disk into a GeneXus object part.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "inputPath": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "inputPath"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_import_object"&#xD;
    },&#xD;
    {&#xD;
      "description": "Inject SDT structures and Procedure signatures of called objects.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "recursive": {&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_inject_context"&#xD;
    },&#xD;
    {&#xD;
      "description": "Use to snapshot an object: metadata, variables, structure, signature. Raw shape, no source text — use genexus_read for code. runtimeIds requires a prior build.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "include": {&#xD;
            "items": {&#xD;
              "enum": [&#xD;
                "metadata",&#xD;
                "variables",&#xD;
                "signature",&#xD;
                "structure",&#xD;
                "parts",&#xD;
                "controls",&#xD;
                "events_repertoire",&#xD;
                "callers",&#xD;
                "runtimeIds"&#xD;
              ],&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "projection": {&#xD;
            "description": "minimal=name+type+lastUpdate; standard=default; verbose=all fields.",&#xD;
            "enum": [&#xD;
              "minimal",&#xD;
              "standard",&#xD;
              "verbose"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_inspect"&#xD;
    },&#xD;
    {&#xD;
      "description": "Manage open KBs and startup config. list/open/close/set_default operate on WorkerPool; set_startup/get_startup mirror IDE 'Set As Startup Object'.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "list",&#xD;
              "open",&#xD;
              "close",&#xD;
              "set_default",&#xD;
              "set_startup",&#xD;
              "get_startup"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "alias": {&#xD;
            "description": "KB alias. open: auto from path basename if omitted.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Object name (required for set_startup).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "path": {&#xD;
            "description": "Absolute KB path (required for open if alias not in config).",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb"&#xD;
    },&#xD;
    {&#xD;
      "description": "Compare two KBs without opening them. Filesystem walk of Objects/&lt;Type&gt;/&lt;Name&gt;/, no SDK. Returns {onlyInA[],onlyInB[],modified[]}.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kbA": {&#xD;
            "description": "KB alias or path.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kbB": {&#xD;
            "description": "KB alias or path.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "kbA",&#xD;
          "kbB"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb_diff"&#xD;
    },&#xD;
    {&#xD;
      "description": "Locate an object in the KB explorer tree (IDE Right-click → Locate). Returns modulePath, fullPath, up to 20 siblings.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "locate"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Object name.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb_explorer"&#xD;
    },&#xD;
    {&#xD;
      "description": "Copy one object's part files from another KB into the active KB. Deps NOT resolved. Re-index after.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "from": {&#xD;
            "description": "Source KB alias or path.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "description": "Object type (case-sensitive: WebPanel, Procedure, Transaction, ...).",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "from",&#xD;
          "name",&#xD;
          "type"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb_import"&#xD;
    },&#xD;
    {&#xD;
      "description": "Generate a Markdown README for the KB: entities, entry points, modules, top-edited objects.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "generate"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "outputPath": {&#xD;
            "description": "Absolute path to write README. Omit to return markdown inline.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_kb_readme"&#xD;
    },&#xD;
    {&#xD;
      "description": "SDK layout/WebForm ops: get_tree, set_property, find_controls, inspect_surface, scan_mutators.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "get_tree",&#xD;
              "set_property",&#xD;
              "find_controls",&#xD;
              "set_properties",&#xD;
              "inspect_surface",&#xD;
              "get_preview",&#xD;
              "scan_mutators",&#xD;
              "rename_printblock",&#xD;
              "add_printblock"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "changes": {&#xD;
            "items": {&#xD;
              "properties": {&#xD;
                "control": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "propertyName": {&#xD;
                  "type": "string"&#xD;
                },&#xD;
                "value": {&#xD;
                  "type": "string"&#xD;
                }&#xD;
              },&#xD;
              "required": [&#xD;
                "control",&#xD;
                "propertyName",&#xD;
                "value"&#xD;
              ],&#xD;
              "type": "object"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "control": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "currentName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "height": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "limit": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "newName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "printBlockName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "propertyName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "query": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "Alias for name (backcompat).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "value": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_layout"&#xD;
    },&#xD;
    {&#xD;
      "description": "Aggregate friction.jsonl (read-only). Returns {totalEntries,byTool,byCode,severityHistogram}. Pair with friction_log action=tail.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "report"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "since": {&#xD;
            "description": "ISO-8601 lower bound (optional).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "until": {&#xD;
            "description": "ISO-8601 upper bound (optional).",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_learning"&#xD;
    },&#xD;
    {&#xD;
      "description": "Build, validate, index, or poll the KB. Long ops are async with operationId. See genexus://kb/tool-help/genexus_lifecycle for actions and target formats.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "build",&#xD;
              "cancel",&#xD;
              "rebuild",&#xD;
              "reorg",&#xD;
              "reorg_preview",&#xD;
              "validate",&#xD;
              "validate-kb",&#xD;
              "sync",&#xD;
              "index",&#xD;
              "status",&#xD;
              "result",&#xD;
              "snapshots-list",&#xD;
              "snapshots-restore"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "buildPlanCap": {&#xD;
            "description": "Build: max nodes before BuildPlanTooLarge (default 200).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "code": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "compact": {&#xD;
            "description": "Status: counts + top-10 errors (default true).",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "estimated_seconds": {&#xD;
            "description": "Build: &lt;20 sync, &gt;=20 async (default 60).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "fastIncremental": {&#xD;
            "description": "EXPERIMENTAL. Skip clean targets via dirty-tracker; falls back to legacy build on miss. See tool-help.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "force": {&#xD;
            "description": "Index: full SDK rescan (clears snapshot).",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "includeCallees": {&#xD;
            "description": "Build: expand call graph so callees compile first (default transitive).",&#xD;
            "enum": [&#xD;
              "none",&#xD;
              "direct",&#xD;
              "transitive"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "limit": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "notifyOnFailure": {&#xD;
            "description": "Build: Slack/Discord webhook posted on terminal=Failed. See tool-help.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "since": {&#xD;
            "description": "Status: prior _meta.snapshot for chained waits.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "skipFullDeploy": {&#xD;
            "description": "EXPERIMENTAL. Skip deploy step (single-target, includeCallees=none). See tool-help.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "snapshotPath": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "Object name(s), taskId, job_id, or op:&lt;id&gt;. Build accepts CSV ('Foo,Bar').",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "wait": {&#xD;
            "description": "Status taskId event-driven block, 0-600s.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "wait_seconds": {&#xD;
            "description": "Status/build long-poll cap, 0-600s.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "wait_until_done": {&#xD;
            "description": "Build/rebuild: block in one turn until terminal (up to wait_seconds, default 600).",&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_lifecycle"&#xD;
    },&#xD;
    {&#xD;
      "description": "List objects with pagination. Feed nextOffset until hasMore=false. Returns minimal shape by default (name, type, path, parent); verbose=true for full shape.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "axiCompact": {&#xD;
            "default": true,&#xD;
            "description": "Compact projection (default true).",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "cursor": {&#xD;
            "description": "Opaque token from prior nextCursor. Use with sort=lastUpdate for stable paging.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "descriptionFilter": {&#xD;
            "description": "Substring on description.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "filter": {&#xD;
            "description": "Legacy: name OR description. Prefer nameFilter/descriptionFilter.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "inline_read_top": {&#xD;
            "description": "0-3. Inline reads of top N.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "limit": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "modifiedBefore": {&#xD;
            "description": "ISO-8601 UTC. Only items with lastUpdate &lt; modifiedBefore.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "nameFilter": {&#xD;
            "description": "Substring on name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "offset": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "parent": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "parentPath": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "pathPrefix": {&#xD;
            "description": "Folder prefix, e.g. 'Root Module/X/'.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "projection": {&#xD;
            "description": "minimal=name+type+lastUpdate; standard=default compact; verbose=all fields. Overrides axiCompact when set.",&#xD;
            "enum": [&#xD;
              "minimal",&#xD;
              "standard",&#xD;
              "verbose"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "since": {&#xD;
            "description": "ISO-8601 UTC. Only items with lastUpdate &gt;= since.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "sort": {&#xD;
            "description": "name (default, type-bucketed) or lastUpdate (newest first).",&#xD;
            "enum": [&#xD;
              "name",&#xD;
              "lastUpdate"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "typeFilter": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "verbose": {&#xD;
            "description": "Full item shape.",&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_list_objects"&#xD;
    },&#xD;
    {&#xD;
      "description": "Read worker_debug.log tail. target filters by object; tail=N (default 100); since=&lt;ISO|'crash'&gt;. Response includes logPath.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "filterCorrelation": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "grep": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "since": {&#xD;
            "description": "ISO-8601 UTC timestamp to filter lines after, or 'crash' to slice from the last ERROR/CRITICAL marker.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "tail": {&#xD;
            "description": "Last N lines (default 100).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "Only return lines mentioning this object name.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_logs"&#xD;
    },&#xD;
    {&#xD;
      "description": "Change variable type atomically. Preserves name + description.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "basedOn": {&#xD;
            "description": "Domain (optional).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "typeName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "varName": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "varName",&#xD;
          "typeName"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_modify_variable"&#xD;
    },&#xD;
    {&#xD;
      "description": "Advisory file lock per (kbPath,target,part) under .gx/locks. Auto-expires after ttlSec. Returns {status,held,holder,path}.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "acquire",&#xD;
              "release",&#xD;
              "status"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "ownerId": {&#xD;
            "description": "Required for acquire/release.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "ttlSec": {&#xD;
            "description": "Default 300, max 86400.",&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "target"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_multi_agent_lock"&#xD;
    },&#xD;
    {&#xD;
      "description": "View navigation report (IDE Right-click → View Navigation). latest=true returns cached report from .gx/navigation-cache; else runs fresh.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "view"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "latest": {&#xD;
            "default": false,&#xD;
            "description": "Return the most recent cached navigation if any; otherwise run fresh.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_navigation"&#xD;
    },&#xD;
    {&#xD;
      "description": "OCR a screenshot PNG. Stub: returns Unwired envelope until Tesseract.NET is added and GXMCP_OCR_ENGINE=tesseract is set.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "path": {&#xD;
            "description": "Absolute path to a PNG.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "path"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_ocr_screenshot"&#xD;
    },&#xD;
    {&#xD;
      "description": "Session welcome: KB info, last 5 edits, top 3 gotchas, top 5 tools. Cheaper than whoami for mid-session refresh.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_orient"&#xD;
    },&#xD;
    {&#xD;
      "description": "Render WebPanel via headless Chrome. Opens launcher, fills parms, navigates, captures HTML/a11y/screenshot, optionally diffs vs baseline.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "default": "render",&#xD;
            "description": "run = auto-resolve launcher (IDE F5 parity). render = explicit name.",&#xD;
            "enum": [&#xD;
              "render",&#xD;
              "run"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "auth": {&#xD;
            "description": "GAM override (mode/user/pass).",&#xD;
            "type": "object"&#xD;
          },&#xD;
          "buildFirst": {&#xD;
            "default": false,&#xD;
            "description": "Build before launch.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "capture": {&#xD;
            "description": "Default ['html','a11y'].",&#xD;
            "items": {&#xD;
              "enum": [&#xD;
                "html",&#xD;
                "a11y",&#xD;
                "screenshot",&#xD;
                "console"&#xD;
              ],&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "click": {&#xD;
            "description": "GX-aware click target.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "diffBaseline": {&#xD;
            "default": false,&#xD;
            "description": "Structural diff vs stored baseline.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "emulate": {&#xD;
            "description": "Device emulation profile passed to chrome-devtools-axi.",&#xD;
            "enum": [&#xD;
              "iPhone12",&#xD;
              "iPhone15Pro",&#xD;
              "iPadPro",&#xD;
              "Pixel7",&#xD;
              "desktop1920",&#xD;
              "desktop1280"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "fill": {&#xD;
            "description": "GX-aware form fills.",&#xD;
            "type": "object"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "launcher": {&#xD;
            "description": "Launcher page (default 'auto').",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "WebPanel name. Optional for action=run.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "network": {&#xD;
            "default": "fast",&#xD;
            "description": "Network throttle profile.",&#xD;
            "enum": [&#xD;
              "fast",&#xD;
              "slow3g",&#xD;
              "fast3g",&#xD;
              "offline"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "parms": {&#xD;
            "description": "Per-call launcher parms.",&#xD;
            "type": "object"&#xD;
          },&#xD;
          "updateBaseline": {&#xD;
            "default": false,&#xD;
            "description": "Persist current as new baseline.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "waitMs": {&#xD;
            "default": 3000,&#xD;
            "description": "Wait ms after nav.",&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_preview"&#xD;
    },&#xD;
    {&#xD;
      "description": "Read or update GeneXus object properties. Note: Description is the title-bar text shown when a WebPanel/Popup is opened via .Popup().",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "get",&#xD;
              "set"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "control": {&#xD;
            "description": "Optional. Layout control name (e.g. BtnConfirmar), variable name with &amp; prefix (e.g. &amp;Alu2RegProf), or attribute name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "propertyName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "value": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_properties"&#xD;
    },&#xD;
    {&#xD;
      "description": "Generate a structured PR description from the last N commits on the current branch via 'git log'. Returns {title, summary, why, changes:[...]}.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "generate"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "last": {&#xD;
            "description": "Commits to read (default 10, max 100).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "workingDir": {&#xD;
            "description": "Override repo root (defaults to active KB path).",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_pr_description"&#xD;
    },&#xD;
    {&#xD;
      "description": "Search objects in active KB. Prefixes: type:, usedby:, parent:, parentPath:, description:. Compact by default. See genexus://kb/tool-help/genexus_query.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "axiCompact": {&#xD;
            "default": true,&#xD;
            "description": "Compact projection (default true).",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "cursor": {&#xD;
            "description": "Opaque token from prior nextCursor. Use with sort=lastUpdate for stable paging.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "domainFilter": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "inline_read_top": {&#xD;
            "description": "0-3. Inline reads of top N.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "limit": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "modifiedBefore": {&#xD;
            "description": "ISO-8601 UTC. Only items with lastUpdate &lt; modifiedBefore.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "query": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "since": {&#xD;
            "description": "ISO-8601 UTC. Only items with lastUpdate &gt;= since.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "sort": {&#xD;
            "description": "relevance (default) or lastUpdate (newest first; bypasses score ranking).",&#xD;
            "enum": [&#xD;
              "relevance",&#xD;
              "lastUpdate"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "typeFilter": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "query"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_query"&#xD;
    },&#xD;
    {&#xD;
      "description": "Read parts of objects. name or targets + parts=[...]. Paginate via offset/limit. See genexus://kb/tool-help/genexus_read.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "limit": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "offset": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "part": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "parts": {&#xD;
            "description": "When set, only the listed parts are returned in a combined response. Mutually exclusive with part/offset/limit.",&#xD;
            "items": {&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "targets": {&#xD;
            "items": {&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_read"&#xD;
    },&#xD;
    {&#xD;
      "description": "Named playbooks + self-extending macros. action=list|describe|run|suggest_macro|crystallize.",&#xD;
      "inputSchema": {&#xD;
        "examples": [&#xD;
          {&#xD;
            "name": "list"&#xD;
          },&#xD;
          {&#xD;
            "name": "wwp_on_transaction"&#xD;
          },&#xD;
          {&#xD;
            "action": "suggest_macro"&#xD;
          }&#xD;
        ],&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "description": "suggest_macro: detect repeated sequences; crystallize: save one as a recipe.",&#xD;
            "enum": [&#xD;
              "list",&#xD;
              "describe",&#xD;
              "run",&#xD;
              "suggest_macro",&#xD;
              "crystallize"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "description": {&#xD;
            "description": "crystallize: human-readable description.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "macroName": {&#xD;
            "description": "crystallize: proposed name from suggest_macro.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "minRepetitions": {&#xD;
            "description": "suggest_macro: threshold (default 3).",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Recipe key (latest version), 'name@v1' (pinned), or 'list'.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "windowMinutes": {&#xD;
            "description": "suggest_macro: history window (default 30).",&#xD;
            "type": "integer"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_recipe"&#xD;
    },&#xD;
    {&#xD;
      "description": "Run GeneXus refactor: rename, extract procedure, or WWP condition set.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "RenameAttribute",&#xD;
              "RenameVariable",&#xD;
              "RenameObject",&#xD;
              "ExtractProcedure",&#xD;
              "WWPSetCondition"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "code": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "controlAttribute": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "newName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "objectName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "procedureName": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "target": {&#xD;
            "description": "Primary object or symbol to refactor.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "value": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_refactor"&#xD;
    },&#xD;
    {&#xD;
      "description": "Rename object/attribute and patch every call-site via CalledBy edges. Routes through RefactorService Rename{Object|Attribute}. Returns standard refactor envelope with patched-site count.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "from": {&#xD;
            "description": "Current name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "to": {&#xD;
            "description": "New name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "type": {&#xD;
            "description": "Object type; pass 'Attribute' for attribute renames.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "from",&#xD;
          "to"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_rename_across_kb"&#xD;
    },&#xD;
    {&#xD;
      "description": "Detect whether N similar objects share enough structure for a pattern. Intersects vars/events/parm-sigs. Returns {commonVariables,commonEvents,divergencePoints,hint}.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "infer"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "source": {&#xD;
            "description": "≥2 object names.",&#xD;
            "items": {&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "source"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_reverse_pattern"&#xD;
    },&#xD;
    {&#xD;
      "description": "Resolve runtime URL for an object (webRoot + aspx + encoded args). gamSession='auto'|{user,pass,...} captures GAM cookies. Does NOT open a browser.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "args": {&#xD;
            "description": "Positional parameter values.",&#xD;
            "type": "array"&#xD;
          },&#xD;
          "gamSession": {&#xD;
            "anyOf": [&#xD;
              {&#xD;
                "type": "string"&#xD;
              },&#xD;
              {&#xD;
                "type": "object"&#xD;
              }&#xD;
            ],&#xD;
            "description": "'auto' (use GXMCP_GAM_USER/PASS env) or {user, pass, repository?, loginUrl?}."&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_run_object"&#xD;
    },&#xD;
    {&#xD;
      "description": "Copy a KB to &lt;configRoot&gt;/sandboxes/&lt;name&gt;/ for throwaway edits. create needs from+name; remove idempotent. Returns {status,path,filesCopied,bytesCopied,alias}.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "create",&#xD;
              "remove"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "from": {&#xD;
            "description": "Source KB alias or path (required for create).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Sandbox name; [A-Za-z0-9_-]+.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "overwrite": {&#xD;
            "type": "boolean"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_sandbox"&#xD;
    },&#xD;
    {&#xD;
      "description": "IDE 'Save As...' — clone object parts under a new name (same type/module). includePatternInstance=true also clones a linked WWP instance.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "dryRun": {&#xD;
            "default": false,&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "includePatternInstance": {&#xD;
            "default": false,&#xD;
            "description": "Also clone linked WorkWithPlus instance.",&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "Source object name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "newName": {&#xD;
            "description": "New object name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "overwrite": {&#xD;
            "default": false,&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "type": {&#xD;
            "description": "Disambiguates ambiguous names.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "name",&#xD;
          "newName"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_save_as"&#xD;
    },&#xD;
    {&#xD;
      "description": "Publish (copy) a screenshot PNG to &lt;kbPath&gt;/.gx/published-screenshots/&lt;UTC&gt;-&lt;basename&gt;. Local only — no remote upload.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "path": {&#xD;
            "description": "Absolute path to a PNG inside the workspace.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "path"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_screenshot_publish"&#xD;
    },&#xD;
    {&#xD;
      "description": "Dump SDK surface (types/methods/props) to docs/sdk-probe/. Use when hunting for entry points.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "outputDir": {&#xD;
            "description": "Absolute path. Default &lt;repo&gt;/docs/sdk-probe/.",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_sdk_probe"&#xD;
    },&#xD;
    {&#xD;
      "description": "Type-locked SDPanel entry: inspect/create/edit. Rejects non-SDPanel targets. Returns the underlying envelope tagged kind='SDPanel'.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "action": {&#xD;
            "enum": [&#xD;
              "inspect",&#xD;
              "create",&#xD;
              "edit"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "content": {&#xD;
            "description": "Part source for edit.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "description": {&#xD;
            "description": "Object description for create.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "name": {&#xD;
            "description": "SDPanel name.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "part": {&#xD;
            "description": "Part name for edit (default Events).",&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action",&#xD;
          "name"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_sd_panel"&#xD;
    },&#xD;
    {&#xD;
      "description": "Regex/semantic search across Procedure/DataProvider/WebPanel/Transaction source.",&#xD;
      "inputSchema": {&#xD;
        "properties": {&#xD;
          "argMatches": {&#xD;
            "description": "Positional arg index to expected literal text.",&#xD;
            "type": "object"&#xD;
          },&#xD;
          "callee": {&#xD;
            "description": "Method/function name (qualified or unqualified).",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "caseSensitive": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "fields": {&#xD;
            "description": "Fields to search. Default [source]. Add caption/description/parmNames to widen.",&#xD;
            "items": {&#xD;
              "enum": [&#xD;
                "source",&#xD;
                "caption",&#xD;
                "description",&#xD;
                "parmNames"&#xD;
              ],&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "includeComments": {&#xD;
            "type": "boolean"&#xD;
          },&#xD;
          "inline_read_top": {&#xD;
            "description": "0-3. Inline reads of top N distinct objects in response.",&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "kb": {&#xD;
            "description": "KB alias.",&#xD;
            "type": "string"&#xD;
          },&#xD;
          "maxResults": {&#xD;
            "type": "integer"&#xD;
          },&#xD;
          "pattern": {&#xD;
            "type": "string"&#xD;
          },&#xD;
          "scope": {&#xD;
            "items": {&#xD;
              "type": "string"&#xD;
            },&#xD;
            "type": "array"&#xD;
          },&#xD;
          "typeFilter": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_search_source"&#xD;
    },&#xD;
    {&#xD;
