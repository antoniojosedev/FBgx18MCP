          },&#xD;
          "severity": {&#xD;
            "enum": [&#xD;
              "info",&#xD;
              "warn",&#xD;
              "error",&#xD;
              "critical"&#xD;
            ],&#xD;
            "type": "string"&#xD;
          },&#xD;
          "tool": {&#xD;
            "type": "string"&#xD;
          }&#xD;
        },&#xD;
        "required": [&#xD;
          "action"&#xD;
        ],&#xD;
        "type": "object"&#xD;
      },&#xD;
      "name": "genexus_friction_log"&#xD;
    },&#xD;
    {&#xD;
